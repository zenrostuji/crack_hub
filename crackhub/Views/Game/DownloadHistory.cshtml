@model IEnumerable<crackhub.Models.Data.DownloadHistory>
@{
    ViewData["Title"] = "Lịch sử tải xuống";
    var currentPage = ViewBag.CurrentPage;
    var totalPages = ViewBag.TotalPages;
    var totalDownloads = ViewBag.TotalDownloads;
    var searchTerm = ViewBag.SearchTerm ?? "";
    var currentSort = ViewBag.CurrentSort ?? "newest";
}

@section Styles {
    <style>
        .download-history-container {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 2rem 0;
        }
        
        .history-header {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 1rem;
            padding: 2rem;
            margin-bottom: 2rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            text-align: center;
        }
        
        .history-controls {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 2rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .download-item {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
            color: white;
        }
        
        .download-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            background: rgba(255, 255, 255, 0.15);
        }
        
        .game-thumbnail {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 0.5rem;
        }
        
        .game-info h5 {
            color: white;
            margin-bottom: 0.5rem;
        }
        
        .game-meta {
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
        }
        
        .download-date {
            background: rgba(255, 255, 255, 0.2);
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            font-size: 0.9rem;
            color: white;
        }
        
        .btn-game-action {
            background: rgba(255, 255, 255, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: white;
            transition: all 0.3s ease;
        }
        
        .btn-game-action:hover {
            background: rgba(255, 255, 255, 0.3);
            color: white;
            transform: translateY(-2px);
        }
        
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: white;
        }
        
        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.6;
        }
        
        .pagination {
            justify-content: center;
            margin-top: 2rem;
        }
        
        .page-link {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            margin: 0 0.2rem;
            border-radius: 0.5rem;
        }
        
        .page-link:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.3);
            color: white;
        }
        
        .page-item.active .page-link {
            background: rgba(255, 255, 255, 0.3);
            border-color: rgba(255, 255, 255, 0.4);
            color: white;
        }
        
        .search-form .form-control {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
        }
        
        .search-form .form-control::placeholder {
            color: rgba(255, 255, 255, 0.7);
        }
        
        .search-form .form-control:focus {
            background: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.4);
            box-shadow: 0 0 0 0.2rem rgba(255, 255, 255, 0.25);
            color: white;
        }
        
        .dropdown-menu {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
    </style>
}

<div class="download-history-container">
    <div class="container">
        <!-- Header -->
        <div class="history-header">
            <h1><i class="fas fa-download me-3"></i>Lịch sử tải xuống</h1>
            <p class="mb-0">Quản lý và theo dõi tất cả các game bạn đã tải xuống</p>
            <div class="mt-3">
                <span class="badge bg-primary fs-6">
                    <i class="fas fa-chart-bar me-2"></i>Tổng cộng: @totalDownloads lượt tải
                </span>
            </div>
        </div>

        <!-- Search and Sort Controls -->
        <div class="history-controls">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <form method="get" class="search-form">
                        <div class="input-group">
                            <input type="text" name="searchTerm" class="form-control" 
                                   placeholder="Tìm kiếm game, nhà phát triển, thể loại..." value="@searchTerm">
                            <button class="btn btn-primary" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <input type="hidden" name="sortOrder" value="@currentSort" />
                        <input type="hidden" name="page" value="1" />
                    </form>
                </div>
                <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" id="sortDropdown" 
                                data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-sort me-2"></i>Sắp xếp
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="sortDropdown">
                            <li><a class="dropdown-item @(currentSort == "newest" ? "active" : "")" 
                                   href="@Url.Action("DownloadHistory", new { sortOrder = "newest", searchTerm = searchTerm, page = 1 })">
                                <i class="fas fa-clock me-2"></i>Mới nhất</a></li>
                            <li><a class="dropdown-item @(currentSort == "oldest" ? "active" : "")" 
                                   href="@Url.Action("DownloadHistory", new { sortOrder = "oldest", searchTerm = searchTerm, page = 1 })">
                                <i class="fas fa-history me-2"></i>Cũ nhất</a></li>
                            <li><a class="dropdown-item @(currentSort == "title" ? "active" : "")" 
                                   href="@Url.Action("DownloadHistory", new { sortOrder = "title", searchTerm = searchTerm, page = 1 })">
                                <i class="fas fa-sort-alpha-down me-2"></i>Tên A-Z</a></li>
                            <li><a class="dropdown-item @(currentSort == "title_desc" ? "active" : "")" 
                                   href="@Url.Action("DownloadHistory", new { sortOrder = "title_desc", searchTerm = searchTerm, page = 1 })">
                                <i class="fas fa-sort-alpha-up me-2"></i>Tên Z-A</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Download History List -->
        @if (Model.Any())
        {
            <div class="row">
                @foreach (var download in Model)
                {
                    <div class="col-12">
                        <div class="download-item">
                            <div class="row align-items-center">
                                <div class="col-md-2">
                                    <img src="@(string.IsNullOrEmpty(download.Game?.CoverImageUrl) ? "/img/no-image.jpg" : download.Game.CoverImageUrl)" 
                                         alt="@download.Game?.Title" class="game-thumbnail" 
                                         onerror="this.src='/img/no-image.jpg'">
                                </div>
                                <div class="col-md-5">
                                    <div class="game-info">
                                        <h5>@download.Game?.Title</h5>
                                        <div class="game-meta">
                                            @if (!string.IsNullOrEmpty(download.Game?.Category?.CategoryName))
                                            {
                                                <span class="me-3">
                                                    <i class="fas fa-tag me-1"></i>@download.Game.Category.CategoryName
                                                </span>
                                            }
                                            @if (!string.IsNullOrEmpty(download.Game?.Developer))
                                            {
                                                <span class="me-3">
                                                    <i class="fas fa-user me-1"></i>@download.Game.Developer
                                                </span>                                            }                                            
                                                <span>
                                                     <i class="fas fa-star me-1"></i>@(download.Game?.AverageRating > 0 ? download.Game.AverageRating.ToString("0.0") : "N/A")
                                                </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="download-date">
                                        <i class="fas fa-calendar me-2"></i>
                                        <div>
                                            <strong>@download.DownloadDate.ToString("dd/MM/yyyy")</strong>
                                            <br>
                                            <small>@download.DownloadDate.ToString("HH:mm")</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2 text-end">
                                    <div class="d-flex flex-column gap-2">
                                        <a href="@Url.Action("Details", "Game", new { id = download.GameId })" 
                                           class="btn btn-sm btn-game-action">
                                            <i class="fas fa-info-circle me-1"></i>Chi tiết
                                        </a>
                                        <a href="@Url.Action("Download", "Game", new { id = download.GameId })" 
                                           class="btn btn-sm btn-game-action download-link" data-game-id="@download.GameId">
                                            <i class="fas fa-download me-1"></i>Tải lại
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <nav aria-label="Download history pagination">
                    <ul class="pagination">
                        @if (currentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("DownloadHistory", new { page = currentPage - 1, sortOrder = currentSort, searchTerm = searchTerm })" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                        }

                        @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("DownloadHistory", new { page = i, sortOrder = currentSort, searchTerm = searchTerm })">@i</a>
                            </li>
                        }

                        @if (currentPage < totalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("DownloadHistory", new { page = currentPage + 1, sortOrder = currentSort, searchTerm = searchTerm })" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-download"></i>
                <h3>Chưa có lịch sử tải xuống</h3>
                <p class="mb-4">
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <span>Không tìm thấy kết quả cho "@searchTerm".</span>
                    }
                    else
                    {
                        <span>Bạn chưa tải xuống game nào. Hãy khám phá thư viện game của chúng tôi!</span>
                    }
                </p>
                <div>
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <a href="@Url.Action("DownloadHistory")" class="btn btn-outline-light me-3">
                            <i class="fas fa-times me-2"></i>Xóa bộ lọc
                        </a>
                    }
                    <a href="@Url.Action("Index", "Game")" class="btn btn-primary">
                        <i class="fas fa-gamepad me-2"></i>Khám phá Game
                    </a>
                </div>
            </div>
        }

        <!-- Back to Profile -->
        <div class="text-center mt-4">
            <a href="@Url.Action("Profile", "Account")" class="btn btn-outline-light">
                <i class="fas fa-user me-2"></i>Quay lại Profile
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Handle download re-download tracking
            $('.download-link').on('click', function() {
                var gameId = $(this).data('game-id');
                $.ajax({
                    url: '@Url.Action("AddDownloadHistory", "Game")',
                    type: 'POST',
                    data: { gameId: gameId }
                });
            });
        });
    </script>
}
