@{
    ViewData["Title"] = "Đã đạt giới hạn tải xuống";
}

@section Styles {
    <style>
        .download-limit-container {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            padding: 2rem 0;
        }
        
        .limit-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 1rem;
            padding: 3rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            text-align: center;
            max-width: 600px;
            margin: 0 auto;
        }
        
        .limit-icon {
            font-size: 4rem;
            color: #e74c3c;
            margin-bottom: 1.5rem;
        }
        
        .limit-title {
            color: #2c3e50;
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 1rem;
        }
        
        .limit-message {
            color: #7f8c8d;
            font-size: 1.1rem;
            margin-bottom: 2rem;
            line-height: 1.6;
        }
        
        .btn-premium {
            background: linear-gradient(135deg, #f39c12 0%, #f1c40f 100%);
            border: none;
            color: white;
            font-weight: bold;
            padding: 0.75rem 2rem;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            margin: 0 0.5rem;
        }
        
        .btn-premium:hover {
            background: linear-gradient(135deg, #e67e22 0%, #f39c12 100%);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(243, 156, 18, 0.4);
        }
        
        .btn-secondary {
            background: #95a5a6;
            border: none;
            color: white;
            padding: 0.75rem 2rem;
            font-size: 1.1rem;
            margin: 0 0.5rem;
            transition: all 0.3s ease;
        }
        
        .btn-secondary:hover {
            background: #7f8c8d;
            color: white;
            transform: translateY(-2px);
        }
        
        .benefits-list {
            text-align: left;
            margin: 2rem 0;
            padding: 1.5rem;
            background: #f8f9fa;
            border-radius: 0.5rem;
        }
        
        .benefits-list h5 {
            color: #2c3e50;
            margin-bottom: 1rem;
            text-align: center;
        }
        
        .benefits-list ul {
            list-style: none;
            padding: 0;
        }
        
        .benefits-list li {
            padding: 0.5rem 0;
            color: #34495e;
        }
        
        .benefits-list li i {
            color: #f39c12;
            margin-right: 0.5rem;
        }
    </style>
}

<div class="download-limit-container">
    <div class="container">
        <div class="limit-card">
            <div class="limit-icon">
                <i class="fas fa-ban"></i>
            </div>
            
            <h1 class="limit-title">Đã đạt giới hạn tải xuống</h1>
            
            <p class="limit-message">
                Bạn đã tải xuống 3 game hôm nay, đây là giới hạn tối đa cho tài khoản thường. 
                Hãy nâng cấp lên Premium để tận hưởng việc tải game không giới hạn!
            </p>
            
            <div class="benefits-list">
                <h5><i class="fas fa-crown me-2"></i>Đặc quyền Premium</h5>
                <ul>
                    <li><i class="fas fa-infinity"></i> Tải xuống không giới hạn mỗi ngày</li>
                    <li><i class="fas fa-bolt"></i> Tốc độ download nhanh hơn</li>
                    <li><i class="fas fa-ad"></i> Không hiển thị quảng cáo</li>
                    <li><i class="fas fa-headset"></i> Hỗ trợ kỹ thuật ưu tiên</li>
                    <li><i class="fas fa-edit"></i> Thay đổi tên hiển thị</li>
                </ul>
            </div>
            
            <div class="d-flex justify-content-center flex-wrap">
                <a href="@Url.Action("Premium", "Home")" class="btn btn-premium">
                    <i class="fas fa-crown me-2"></i>Nâng cấp Premium
                </a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                    <i class="fas fa-home me-2"></i>Về trang chủ
                </a>
            </div>
            
            <div class="mt-4">
                <small class="text-muted">
                    Giới hạn tải xuống sẽ được reset vào 00:00 hôm sau.
                </small>
            </div>
        </div>
    </div>
</div>
